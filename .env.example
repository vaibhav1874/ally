# Ally Configuration Example
# Copy this file to '.env' inside the 'backend' folder and update values.

# System Port (default is 8000)
PORT=8000
HOST=127.0.0.1

# Enable/Disable debug mode (true/false)
DEBUG=true

# Ollama Host Endpoint URL (default local endpoint)
OLLAMA_HOST=http://localhost:11434

# The Text model to use for chats and tool actions
# Suggested: llama3.1, qwen2.5, mistral
OLLAMA_MODEL=llama3.1

# The Multimodal vision model to use for screen monitor grabs
# Suggested: llava
OLLAMA_VISION_MODEL=llava
