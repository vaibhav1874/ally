# Ally Configuration Example
# Copy this file to '.env' inside the 'backend' folder and update values.

# System Port (default is 8000)
PORT=8000
HOST=127.0.0.1

# Enable/Disable debug mode (true/false)
DEBUG=true

# REQUIRED: Your Gemini API Key for Ally's intelligence and screen understanding.
# Get one from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
